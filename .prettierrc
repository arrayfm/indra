{
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "bracketSpacing": true,
  "jsxBracketSameLine": false,
  "trailingComma": "es5",
  "plugins": [
    "prettier-plugin-tailwindcss"  
  ],
  "importOrderSeparation": true,
  "importOrder": ["^server-only", "<THIRD_PARTY_MODULES>", "^@/(.*)$", "^[./]"]
}
